<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Electrostatic Archimedean Sieve Simulator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <style>
        body { margin: 0; overflow: hidden; background-color: #020617; color: #f8fafc; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; display: flex; flex-direction: column; height: 100vh; }
        #ui-layer { flex: 0 0 auto; background: rgba(10, 15, 30, 0.95); border-bottom: 1px solid rgba(16, 185, 129, 0.3); padding: 12px 20px; box-sizing: border-box; display: flex; flex-direction: row; gap: 15px; flex-wrap: wrap; justify-content: space-between; align-items: flex-start; z-index: 10; box-shadow: 0 4px 30px rgba(0,0,0,0.8); }
        #canvas-container { flex: 1 1 auto; position: relative; width: 100%; overflow: hidden; background: radial-gradient(circle at center, #020617 0%, #000000 100%); }
        
        .ui-section { display: flex; flex-direction: column; gap: 8px; }
        h1 { margin: 0; font-size: 1.15rem; color: #10b981; text-transform: uppercase; letter-spacing: 2px; line-height: 1.2; text-shadow: 0 0 10px rgba(16, 185, 129, 0.5); }
        p.subtitle { color: #94a3b8; font-size: 0.65rem; margin: 0; text-transform: uppercase; letter-spacing: 1px; }
        
        .toggles-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 8px 15px; }
        .toggle-row { display: flex; justify-content: space-between; align-items: center; padding-bottom: 3px; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .toggle-label { display: flex; flex-direction: column; flex: 1; margin-right: 10px; }
        .toggle-title { font-weight: bold; font-size: 0.75rem; color: #f1f5f9; }
        .toggle-desc { font-size: 0.6rem; color: #64748b; margin-top: 1px; }
        
        .switch { position: relative; display: inline-block; width: 32px; height: 16px; flex-shrink: 0; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #1e293b; transition: .3s; border-radius: 16px; border: 1px solid #334155; }
        .slider:before { position: absolute; content: ""; height: 12px; width: 12px; left: 2px; bottom: 1px; background-color: #94a3b8; transition: .3s; border-radius: 50%; }
        input:checked + .slider { background-color: rgba(16, 185, 129, 0.2); border-color: #10b981; }
        input:checked + .slider:before { transform: translateX(14px); background-color: #10b981; box-shadow: 0 0 6px #10b981; }
        
        /* Purple switch for Inward Squeeze */
        input.purple-switch:checked + .slider { background-color: rgba(168, 85, 247, 0.2); border-color: #a855f7; }
        input.purple-switch:checked + .slider:before { background-color: #a855f7; box-shadow: 0 0 6px #a855f7; }

        .custom-slider { -webkit-appearance: none; appearance: none; width: 100%; height: 16px; display: block; background: transparent; margin: 4px 0; outline: none; }
        .custom-slider::-webkit-slider-runnable-track { width: 100%; height: 4px; cursor: pointer; background: #1e293b; border-radius: 2px; border: 1px solid #334155; }
        .custom-slider::-webkit-slider-thumb { border: none; height: 14px; width: 14px; border-radius: 50%; background: #10b981; cursor: pointer; -webkit-appearance: none; appearance: none; margin-top: -6px; box-shadow: 0 0 8px #10b981; }

        .slider-yellow::-webkit-slider-thumb { background: #eab308; box-shadow: 0 0 8px #eab308; }
        .slider-yellow::-webkit-slider-runnable-track { border-color: #713f12; }

        .custom-slider.slider-purple::-webkit-slider-thumb { background: #a855f7; box-shadow: 0 0 8px #a855f7; }
        .custom-slider.slider-purple::-webkit-slider-runnable-track { border-color: #581c87; }

        #status-panel { min-width: 280px; padding-left: 15px; border-left: 1px solid rgba(16, 185, 129, 0.2); }
        #status-text { font-family: monospace; color: #e2e8f0; font-size: 0.75rem; line-height: 1.5; }
        
        .legend { display: flex; flex-direction: column; gap: 3px; margin-top: 4px; font-size: 0.65rem; color: #94a3b8; }
        .legend-item { display: flex; align-items: center; gap: 5px; }
        .dot { width: 7px; height: 7px; border-radius: 50%; }

        .pan-btn { padding: 6px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.5); color: #10b981; border-radius: 4px; cursor: pointer; text-transform: uppercase; font-size: 0.6rem; font-weight: bold; transition: all 0.2s; flex: 1; user-select: none; }
        .pan-btn:hover { background: rgba(16, 185, 129, 0.2); }
        .axis-btn { background: #0f172a; color: #f8fafc; border: 1px solid #334155; flex: 0.6; }
        .axis-btn:hover { background: #1e293b; border-color: #475569; }
        
        .metric-good { color: #10b981; font-weight: bold; }
        .metric-bad { color: #ef4444; font-weight: bold; }
        .metric-warn { color: #f59e0b; font-weight: bold; }
        
        .micro-btn { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3); color: #fff; width: 20px; height: 20px; display: flex; justify-content: center; align-items: center; border-radius: 4px; cursor: pointer; font-weight: bold; font-size: 0.7rem; flex-shrink: 0; }
        .micro-btn:hover { background: rgba(255,255,255,0.2); }
        .micro-btn:active { background: rgba(255,255,255,0.4); }
    </style>
</head>
<body>

    <div id="ui-layer">
        <div class="ui-section" style="flex: 1; min-width: 240px;">
            <h1>Archimedean Sieve</h1>
            <p class="subtitle">Radioisotope Remediation Matrix</p>
            
            <div class="legend mt-2 mb-2">
                <div class="legend-item"><div class="dot bg-[#0ea5e9]"></div> Bulk H₂O (Clean Fluid)</div>
                <div class="legend-item"><div class="dot bg-[#39ff14] shadow-[0_0_5px_#39ff14]"></div> HTO / Tritium (Radioactive Target)</div>
                <div class="legend-item"><div class="dot bg-[#a855f7] shadow-[0_0_5px_#a855f7]"></div> 18-Pole Inward Squeeze (nDEP)</div>
                <div class="legend-item"><div class="dot border border-[#10b981]"></div> twDEP Archimedean Corkscrew</div>
            </div>

            <div style="display: flex; gap: 8px; margin-top: 4px;">
                <button id="pan-left-btn" class="pan-btn">&larr; Tilt</button>
                <button id="axis-toggle-btn" class="pan-btn axis-btn">Axis: X</button>
                <button id="pan-right-btn" class="pan-btn">Tilt &rarr;</button>
            </div>
            
            <div class="text-[9px] text-slate-400 font-bold bg-slate-900/80 border border-emerald-900/50 p-2 rounded mt-2 text-center shadow-[0_0_10px_rgba(0,0,0,0.5)]">
                DRAG to rotate camera • SCROLL to zoom
            </div>
        </div>

        <div class="ui-section" style="flex: 2; min-width: 320px; border-left: 1px solid rgba(255,255,255,0.05); padding-left: 15px;">
            <div class="toggles-grid" style="margin-top: 2px;">
                
                <div style="background: rgba(168, 85, 247, 0.05); border: 1px solid rgba(168, 85, 247, 0.2); padding: 8px; border-radius: 6px; margin-top: 4px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                        <span class="toggle-title text-purple-400">18-Pole Inward Squeeze (nDEP)</span>
                        <span id="ndep-label" class="font-mono text-purple-400 font-bold text-xs">80%</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <button id="ndep-minus" class="micro-btn">-</button>
                        <input type="range" id="ndep-slider" class="custom-slider slider-purple" min="0" max="100" step="1" value="80" style="margin:0;">
                        <button id="ndep-plus" class="micro-btn">+</button>
                    </div>
                </div>

                <div style="background: rgba(16, 185, 129, 0.05); border: 1px solid rgba(16, 185, 129, 0.2); padding: 8px; border-radius: 6px; margin-top: 4px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                        <span class="toggle-title text-emerald-400">Archimedean Corkscrew (twDEP)</span>
                        <span id="twdep-label" class="font-mono text-emerald-400 font-bold text-xs">80%</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <button id="twdep-minus" class="micro-btn">-</button>
                        <input type="range" id="twdep-slider" class="custom-slider" min="0" max="100" step="1" value="80" style="margin:0;">
                        <button id="twdep-plus" class="micro-btn">+</button>
                    </div>
                </div>

                <div class="toggle-row" style="margin-top: 4px;">
                    <div class="toggle-label">
                        <span class="toggle-title text-yellow-400">Acousto-Electric Ratchet</span>
                        <span class="toggle-desc">Breaks friction, allows hopped-spiral extraction.</span>
                    </div>
                    <label class="switch"><input type="checkbox" id="toggle-ratchet" checked><span class="slider" style="border-color:#eab308;"></span></label>
                </div>

                <div style="grid-column: 1 / -1; background: rgba(16, 185, 129, 0.05); border: 1px solid rgba(16, 185, 129, 0.2); padding: 8px; border-radius: 6px; margin-top: 4px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2px;">
                        <span class="toggle-title text-emerald-400">Fluid Velocity (Flow Rate)</span>
                        <span id="speed-label" class="font-mono text-emerald-400 font-bold text-xs">1.0x</span>
                    </div>
                    <input type="range" id="speed-slider" class="custom-slider" min="0.1" max="3.0" step="0.1" value="1.0">
                </div>

            </div>
        </div>

        <div class="ui-section" id="status-panel">
            <h2 class="text-[9px] font-black text-slate-500 uppercase tracking-widest mb-2">Extraction Telemetry</h2>
            <div id="status-text">Initializing Mechanics...</div>
        </div>
    </div>

    <div id="canvas-container"></div>

    <script>
        // --- THREE.JS SETUP ---
        const container = document.getElementById('canvas-container');
        const scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x020617, 0.006);

        let width = container.clientWidth;
        let height = container.clientHeight;

        const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
        camera.position.set(0, 0, 130);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(width, height);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        container.appendChild(renderer.domElement);

        const controls = new THREE.OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
        controls.target.set(0, -10, 0);

        // --- MASTER GROUP ---
        const sieveGroup = new THREE.Group();
        scene.add(sieveGroup);

        // --- LIGHTING ---
        const ambientLight = new THREE.AmbientLight(0x0f172a, 3.0);
        scene.add(ambientLight);

        const dirLight = new THREE.DirectionalLight(0xffffff, 1.5);
        dirLight.position.set(20, 40, 30);
        scene.add(dirLight);

        const glowLight = new THREE.PointLight(0x10b981, 1.5, 60);
        glowLight.position.set(0, -15, 0);
        sieveGroup.add(glowLight);

        // --- GEOMETRY: CONDUITS ---
        const pipeMaterial = new THREE.MeshPhysicalMaterial({
            color: 0x1e293b,
            metalness: 0.1,
            roughness: 0.1,
            transparent: true,
            opacity: 0.35,
            side: THREE.DoubleSide,
            depthWrite: false
        });

        const pipeWireframe = new THREE.MeshBasicMaterial({
            color: 0x334155,
            wireframe: true,
            transparent: true,
            opacity: 0.15
        });

        // Main 13µm Conduit (Scaled up for visualization)
        const mainRadius = 8;
        const mainLength = 120;
        const mainGeo = new THREE.CylinderGeometry(mainRadius, mainRadius, mainLength, 32, 1, true);
        const mainPipe = new THREE.Mesh(mainGeo, pipeMaterial);
        const mainPipeWire = new THREE.Mesh(mainGeo, pipeWireframe);
        sieveGroup.add(mainPipe);
        sieveGroup.add(mainPipeWire);

        // Lateral Extraction Chute (Located 2/3 down)
        const sideRadius = 9; 
        const sideLength = 40;
        const sideGeo = new THREE.CylinderGeometry(sideRadius, sideRadius, sideLength, 32, 1, true);
        const sidePipe = new THREE.Mesh(sideGeo, pipeMaterial);
        const sidePipeWire = new THREE.Mesh(sideGeo, pipeWireframe);
        
        const sideY = -20; 
        sidePipe.position.set(sideLength/2 + mainRadius - 1, sideY, 0);
        sidePipe.rotation.z = Math.PI / 2;
        sidePipeWire.position.copy(sidePipe.position);
        sidePipeWire.rotation.z = sidePipe.rotation.z;
        
        sieveGroup.add(sidePipe);
        sieveGroup.add(sidePipeWire);

        // Visualizing the Inward Pinch (nDEP) Field
        const pinchGeo = new THREE.CylinderGeometry(mainRadius * 0.4, mainRadius * 0.4, mainLength, 16, 1, true);
        const pinchMat = new THREE.MeshBasicMaterial({
            color: 0xa855f7, transparent: true, opacity: 0.15, side: THREE.DoubleSide, blending: THREE.AdditiveBlending
        });
        const pinchCylinder = new THREE.Mesh(pinchGeo, pinchMat);
        sieveGroup.add(pinchCylinder);

        // Visualizing the Outward Archimedean Corkscrew Wave (twDEP)
        class HelixCurve extends THREE.Curve {
            constructor(radius, height, turns) {
                super();
                this.radius = radius;
                this.height = height;
                this.turns = turns;
            }
            getPoint(t, optionalTarget = new THREE.Vector3()) {
                const y = (t - 0.5) * this.height;
                const angle = t * Math.PI * 2 * this.turns;
                const x = Math.cos(angle) * this.radius;
                const z = Math.sin(angle) * this.radius;
                return optionalTarget.set(x, y, z);
            }
        }
        
        const helixPath = new HelixCurve(mainRadius - 0.5, mainLength + 10, 12); 
        const corkscrewGeo = new THREE.TubeGeometry(helixPath, 300, 0.4, 8, false);
        const corkscrewMat = new THREE.MeshBasicMaterial({ color: 0x10b981, transparent: true, opacity: 0.6 });
        const corkscrew = new THREE.Mesh(corkscrewGeo, corkscrewMat);
        sieveGroup.add(corkscrew);

        // --- PARTICLE SYSTEM (FLUID DYNAMICS) ---
        const numH2O = 2500;
        const numHTO = 250; 
        
        const geoH2O = new THREE.SphereGeometry(0.3, 8, 8);
        const matH2O = new THREE.MeshStandardMaterial({ color: 0x0ea5e9, metalness: 0.1, roughness: 0.2 });
        const instH2O = new THREE.InstancedMesh(geoH2O, matH2O, numH2O);
        
        const geoHTO = new THREE.SphereGeometry(0.4, 16, 16);
        const matHTO = new THREE.MeshStandardMaterial({ color: 0x39ff14, emissive: 0x10b981, emissiveIntensity: 0.5, metalness: 0.5, roughness: 0.1 });
        const instHTO = new THREE.InstancedMesh(geoHTO, matHTO, numHTO);

        sieveGroup.add(instH2O);
        sieveGroup.add(instHTO);

        // Particle Data Arrays
        const particlesH2O = new Float32Array(numH2O * 3);
        const statesH2O = new Uint8Array(numH2O);
        
        const particlesHTO = new Float32Array(numHTO * 3);
        const statesHTO = new Uint8Array(numHTO);

        // Initialization
        function spawnParticle(arr, i, isSide = false) {
            let r = Math.sqrt(Math.random()) * (mainRadius - 0.5);
            let theta = Math.random() * Math.PI * 2;
            arr[i*3] = r * Math.cos(theta); // x
            arr[i*3+1] = (mainLength / 2) + Math.random() * 20; // y
            arr[i*3+2] = r * Math.sin(theta); // z
        }

        for (let i = 0; i < numH2O; i++) { spawnParticle(particlesH2O, i); statesH2O[i] = 0; }
        for (let i = 0; i < numHTO; i++) { spawnParticle(particlesHTO, i); statesHTO[i] = 0; }

        const dummy = new THREE.Object3D();

        // --- UI & PHYSICS CONTROLS ---
        const sNDEP = document.getElementById('ndep-slider');
        const lNDEP = document.getElementById('ndep-label');
        const sTWDEP = document.getElementById('twdep-slider');
        const lTWDEP = document.getElementById('twdep-label');
        const tRatchet = document.getElementById('toggle-ratchet');
        const sSpeed = document.getElementById('speed-slider');
        const lSpeed = document.getElementById('speed-label');
        const statusText = document.getElementById('status-text');

        sSpeed.addEventListener('input', e => { lSpeed.innerText = parseFloat(e.target.value).toFixed(1) + 'x'; });
        sNDEP.addEventListener('input', e => { lNDEP.innerText = e.target.value + '%'; });
        sTWDEP.addEventListener('input', e => { lTWDEP.innerText = e.target.value + '%'; });

        function dispatchInput(el) { el.dispatchEvent(new Event('input')); }
        document.getElementById('ndep-minus').addEventListener('click', () => { sNDEP.value = Math.max(0, parseInt(sNDEP.value) - 1); dispatchInput(sNDEP); });
        document.getElementById('ndep-plus').addEventListener('click', () => { sNDEP.value = Math.min(100, parseInt(sNDEP.value) + 1); dispatchInput(sNDEP); });
        document.getElementById('twdep-minus').addEventListener('click', () => { sTWDEP.value = Math.max(0, parseInt(sTWDEP.value) - 1); dispatchInput(sTWDEP); });
        document.getElementById('twdep-plus').addEventListener('click', () => { sTWDEP.value = Math.min(100, parseInt(sTWDEP.value) + 1); dispatchInput(sTWDEP); });

        // --- MODEL ROTATION MODIFIER ---
        const btnAxisToggle = document.getElementById('axis-toggle-btn');
        let currentRotAxis = 'X';
        
        btnAxisToggle.addEventListener('click', () => {
            if (currentRotAxis === 'X') currentRotAxis = 'Z';
            else if (currentRotAxis === 'Z') currentRotAxis = 'Y';
            else currentRotAxis = 'X';
            btnAxisToggle.innerText = `Axis: ${currentRotAxis}`;
        });

        document.getElementById('pan-left-btn').addEventListener('click', () => { 
            const step = Math.PI / 16;
            if (currentRotAxis === 'X') sieveGroup.rotation.x -= step;
            if (currentRotAxis === 'Y') sieveGroup.rotation.y -= step;
            if (currentRotAxis === 'Z') sieveGroup.rotation.z -= step;
        });
        
        document.getElementById('pan-right-btn').addEventListener('click', () => { 
            const step = Math.PI / 16;
            if (currentRotAxis === 'X') sieveGroup.rotation.x += step;
            if (currentRotAxis === 'Y') sieveGroup.rotation.y += step;
            if (currentRotAxis === 'Z') sieveGroup.rotation.z += step;
        });

        // Telemetry Counters
        let stats = {
            totalH2O: 0,
            totalHTO: 0,
            extractedHTO: 0,
            missedHTO: 0,
            contaminatedH2O: 0
        };

        function updateTelemetry() {
            let htoEfficacy = stats.totalHTO > 0 ? (stats.extractedHTO / stats.totalHTO * 100).toFixed(1) : "100.0";
            let h2oPurity = stats.totalH2O > 0 ? ((stats.totalH2O - stats.contaminatedH2O) / stats.totalH2O * 100).toFixed(2) : "100.00";

            let html = `Fluid Processed: <span class="text-white">${stats.totalH2O + stats.totalHTO} units</span><br><br>`;
            
            const ndepStrength = parseFloat(sNDEP.value) / 100.0;
            const pinchPower = Math.pow(ndepStrength, 2.5);
            const twdepStrength = parseFloat(sTWDEP.value) / 100.0;
            const ratchetActive = tRatchet.checked;
            
            let f_twdep = 0.8 * twdepStrength;
            let f_ndep = 0.6 * pinchPower;
            let net = f_twdep - f_ndep;
            
            let calibStatus = "";
            if (net > 0.15 && !ratchetActive) calibStatus = '<span class="metric-bad animate-pulse">CRITICAL FAILURE (Wall Clog / Flow Stalled)</span>';
            else if (net < -0.01) calibStatus = '<span class="metric-bad">UNDER-POWERED (Isotopes Trapped in Core)</span>';
            else if (net >= -0.01 && net <= 0.15) calibStatus = '<span class="metric-good">OPTIMAL (Smooth Extraction)</span>';
            else if (net > 0.15) calibStatus = '<span class="metric-warn">OVER-POWERED (High Wall Friction)</span>';
            
            html += `Force Calibration: ${calibStatus}<br>`;
            html += `> Net Radial Vector: <span class="text-white">${net > 0 ? '+' : ''}${net.toFixed(3)}</span><br><br>`;

            html += `HTO Extraction Efficacy: <span class="${htoEfficacy > 95 ? 'metric-good' : 'metric-bad'}">${htoEfficacy}%</span><br>`;
            html += `> Captured Sludge: <span class="text-emerald-400">${stats.extractedHTO}</span><br>`;
            html += `> Missed (Leaked): <span class="text-red-400">${stats.missedHTO}</span><br><br>`;

            html += `Primary Effluent Purity: <span class="${h2oPurity > 99 ? 'metric-good' : 'metric-warn'}">${h2oPurity}%</span><br>`;
            html += `> Cross-Contamination: <span class="text-orange-400">${stats.contaminatedH2O} H₂O units lost</span>`;

            statusText.innerHTML = html;
        }

        window.addEventListener('resize', () => {
            width = container.clientWidth;
            height = container.clientHeight;
            camera.aspect = width / height;
            camera.updateProjectionMatrix();
            renderer.setSize(width, height);
        });

        // --- MAIN ANIMATION LOOP ---
        function animate() {
            requestAnimationFrame(animate);
            controls.update();

            const speed = parseFloat(sSpeed.value);
            const ndepStrength = parseFloat(sNDEP.value) / 100.0;
            const pinchPower = Math.pow(ndepStrength, 2.5);
            const twdepStrength = parseFloat(sTWDEP.value) / 100.0;
            const ratchetActive = tRatchet.checked;

            const baseVy = 0.8 * speed;

            // 1. Update Inward Pinch Visuals
            pinchCylinder.visible = ndepStrength > 0;
            if (ndepStrength > 0) {
                pinchCylinder.material.opacity = (0.05 + ndepStrength * 0.15) + Math.sin(Date.now() * 0.01) * 0.05;
                let pinchScale = 1.0 - (pinchPower * 0.7);
                pinchCylinder.scale.set(pinchScale, 1, pinchScale);
            }

            // 2. Update Archimedean Corkscrew Wave Visuals
            corkscrew.visible = twdepStrength > 0;
            if (twdepStrength > 0) {
                corkscrew.material.opacity = 0.2 + (twdepStrength * 0.6);
                corkscrew.rotation.y -= baseVy * 0.15 * (0.2 + twdepStrength * 0.8); 
            }

            // Physics Parameters
            const fastLaneRadius = mainRadius * 0.3;
            const wallHoverRadius = mainRadius - 1.2;
            const sidePipeEntryYTop = sideY + sideRadius - 1;
            const sidePipeEntryYBot = sideY - sideRadius + 1;

            // 3. Process H2O Particles (Bulk Fluid)
            for (let i = 0; i < numH2O; i++) {
                let x = particlesH2O[i*3];
                let y = particlesH2O[i*3+1];
                let z = particlesH2O[i*3+2];
                let state = statesH2O[i];

                if (state === 0) {
                    y -= baseVy * (1.0 + pinchPower * 0.4); 
                    let r = Math.sqrt(x*x + z*z);
                    
                    if (pinchPower > 0) {
                        let f_ndep = 0.6 * pinchPower;
                        if (r > f_ndep) {
                            x -= (x/r) * f_ndep;
                            z -= (z/r) * f_ndep;
                        } else {
                            x = 0; z = 0;
                        }
                    }
                    
                    let diffusion = 0.4 * (1.0 - pinchPower); 
                    x += (Math.random() - 0.5) * diffusion;
                    z += (Math.random() - 0.5) * diffusion;
                        
                    r = Math.sqrt(x*x + z*z);
                    if (r > mainRadius - 0.5) {
                        x = (x/r) * (mainRadius - 0.5);
                        z = (z/r) * (mainRadius - 0.5);
                    }

                    if (y < sidePipeEntryYTop && y > sidePipeEntryYBot && x > mainRadius - 2.5 && Math.abs(z) < sideRadius - 2) {
                        if (ratchetActive || Math.random() > 0.5) {
                            statesH2O[i] = 1;
                            stats.contaminatedH2O++;
                        }
                    }

                    if (y < -mainLength/2) {
                        spawnParticle(particlesH2O, i);
                        stats.totalH2O++;
                    } else {
                        particlesH2O[i*3] = x; particlesH2O[i*3+1] = y; particlesH2O[i*3+2] = z;
                    }
                } else if (state === 1) {
                    x += baseVy * 0.8;
                    y += (sideY - y) * 0.1;
                    z *= 0.95;

                    if (x > sideLength + mainRadius) {
                        spawnParticle(particlesH2O, i);
                        statesH2O[i] = 0;
                        stats.totalH2O++;
                    } else {
                        particlesH2O[i*3] = x; particlesH2O[i*3+1] = y; particlesH2O[i*3+2] = z;
                    }
                }

                dummy.position.set(particlesH2O[i*3], particlesH2O[i*3+1], particlesH2O[i*3+2]);
                dummy.updateMatrix();
                instH2O.setMatrixAt(i, dummy.matrix);
            }

            // 4. Process HTO Particles (Radioactive Targets)
            for (let i = 0; i < numHTO; i++) {
                let x = particlesHTO[i*3];
                let y = particlesHTO[i*3+1];
                let z = particlesHTO[i*3+2];
                let state = statesHTO[i];

                if (state === 0) {
                    let currentVy = baseVy;
                    let r = Math.sqrt(x*x + z*z);
                    if (r === 0) { x = 0.1; r = 0.1; }

                    // --- COMPETING FORCES PHYSICS ---
                    let f_twdep = 0.8 * twdepStrength;
                    let f_ndep = 0.6 * pinchPower;
                    let net_radial_force = f_twdep - f_ndep;
                    
                    if (net_radial_force < 0 && r <= Math.abs(net_radial_force)) {
                        x = 0.01; z = 0.01; r = 0.014;
                    } else if (net_radial_force !== 0) {
                        x += (x/r) * net_radial_force;
                        z += (z/r) * net_radial_force;
                    }
                    
                    r = Math.sqrt(x*x + z*z);
                    let isAtWall = r >= wallHoverRadius - 0.1;

                    if (r > wallHoverRadius) {
                        x = (x/r) * wallHoverRadius;
                        z = (z/r) * wallHoverRadius;
                        r = wallHoverRadius;
                        isAtWall = true;
                    } else if (r < 0.1) {
                        x = 0.01; z = 0.01; r = 0.014;
                    }

                    // --- CLOGGING & RATCHET PHYSICS ---
                    if (isAtWall && net_radial_force > 0) {
                        let wallPressure = Math.min(1.0, net_radial_force * 1.5);
                        
                        if (ratchetActive) {
                            // Ratchet breaks friction, keeps flow moving via hops
                            currentVy = baseVy * (1.0 - wallPressure * 0.5); 
                            
                            let hopPhase = Math.max(0, Math.sin(y * 6.0)); 
                            let hopDist = hopPhase * 0.8 * wallPressure;
                            x = (x/r) * (r - hopDist);
                            z = (z/r) * (r - hopDist);
                            
                            currentVy += hopPhase * baseVy * 0.7 * wallPressure;
                        } else {
                            // FAILURE MODE: No ratchet -> Massive friction causes complete CLOG
                            currentVy = baseVy * (1.0 - wallPressure * 1.2); 
                            if (currentVy <= 0.05) {
                                currentVy = 0; // Stuck against the wall
                                
                                // Particles clump, jitter, and roll over each other chaotically
                                x += (Math.random() - 0.5) * 0.8;
                                y += (Math.random() - 0.5) * 0.8;
                                z += (Math.random() - 0.5) * 0.8;
                                
                                // Re-normalize so they don't break through the pipe wall visually
                                let tempR = Math.sqrt(x*x + z*z);
                                if (tempR > wallHoverRadius) {
                                    x = (x/tempR) * wallHoverRadius;
                                    z = (z/tempR) * wallHoverRadius;
                                }
                            }
                        }
                    }
                    
                    // Angular Force: Corkscrew physically spins them
                    if (twdepStrength > 0 && currentVy > 0) {
                        let spinSpeed = currentVy * 0.4 * twdepStrength; 
                        let angle = Math.atan2(z, x) + spinSpeed;
                        let currentR = Math.sqrt(x*x + z*z);
                        x = Math.cos(angle) * currentR;
                        z = Math.sin(angle) * currentR;
                    }

                    y -= currentVy;

                    // Check for Extraction
                    if (y < sidePipeEntryYTop && y > sidePipeEntryYBot && x > mainRadius - 3.0 && Math.abs(z) < sideRadius - 1) {
                        if (ratchetActive) {
                            statesHTO[i] = 1;
                            stats.extractedHTO++;
                        } else if (Math.random() > 0.9) {
                            statesHTO[i] = 1;
                            stats.extractedHTO++;
                        }
                    }

                    // Only recycle particles that actually fall out the bottom
                    if (y < -mainLength/2) {
                        spawnParticle(particlesHTO, i);
                        stats.totalHTO++;
                        stats.missedHTO++;
                    } else {
                        particlesHTO[i*3] = x; particlesHTO[i*3+1] = y; particlesHTO[i*3+2] = z;
                    }
                } else if (state === 1) {
                    x += baseVy * 0.6; 
                    y += (sideY - y) * 0.15; 
                    
                    let angle = Math.atan2(z, y - sideY) + (baseVy * 0.1);
                    let currentR = Math.sqrt((y - sideY)*(y - sideY) + z*z) * 0.95;
                    y = sideY + Math.cos(angle) * currentR;
                    z = Math.sin(angle) * currentR;

                    if (x > sideLength + mainRadius) {
                        spawnParticle(particlesHTO, i);
                        statesHTO[i] = 0;
                        stats.totalHTO++;
                    } else {
                        particlesHTO[i*3] = x; particlesHTO[i*3+1] = y; particlesHTO[i*3+2] = z;
                    }
                }

                dummy.position.set(particlesHTO[i*3], particlesHTO[i*3+1], particlesHTO[i*3+2]);
                dummy.updateMatrix();
                instHTO.setMatrixAt(i, dummy.matrix);
            }

            instH2O.instanceMatrix.needsUpdate = true;
            instHTO.instanceMatrix.needsUpdate = true;

            if (Math.random() < 0.1) updateTelemetry();

            renderer.render(scene, camera);
        }

        animate();
    </script>
