<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Electrostatic Archimedean Sieve Simulator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <style>
        body { margin: 0; overflow: hidden; background-color: #020617; color: #f8fafc; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; display: flex; flex-direction: column; height: 100vh; }
        #ui-layer { flex: 0 0 auto; background: rgba(10, 15, 30, 0.95); border-bottom: 1px solid rgba(16, 185, 129, 0.3); padding: 12px 20px; box-sizing: border-box; display: flex; flex-direction: row; gap: 15px; flex-wrap: wrap; justify-content: space-between; align-items: flex-start; z-index: 10; box-shadow: 0 4px 30px rgba(0,0,0,0.8); }
        #canvas-container { flex: 1 1 auto; position: relative; width: 100%; overflow: hidden; background: radial-gradient(circle at center, #020617 0%, #000000 100%); }
        
        .ui-section { display: flex; flex-direction: column; gap: 8px; }
        h1 { margin: 0; font-size: 1.15rem; color: #10b981; text-transform: uppercase; letter-spacing: 2px; line-height: 1.2; text-shadow: 0 0 10px rgba(16, 185, 129, 0.5); }
        p.subtitle { color: #94a3b8; font-size: 0.65rem; margin: 0; text-transform: uppercase; letter-spacing: 1px; }
        
        .toggles-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 8px 15px; }
        .toggle-row { display: flex; justify-content: space-between; align-items: center; padding-bottom: 3px; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .toggle-label { display: flex; flex-direction: column; flex: 1; margin-right: 10px; }
        .toggle-title { font-weight: bold; font-size: 0.75rem; color: #f1f5f9; }
        .toggle-desc { font-size: 0.6rem; color: #64748b; margin-top: 1px; }
        
        .switch { position: relative; display: inline-block; width: 32px; height: 16px; flex-shrink: 0; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #1e293b; transition: .3s; border-radius: 16px; border: 1px solid #334155; }
        .slider:before { position: absolute; content: ""; height: 12px; width: 12px; left: 2px; bottom: 1px; background-color: #94a3b8; transition: .3s; border-radius: 50%; }
        input:checked + .slider { background-color: rgba(16, 185, 129, 0.2); border-color: #10b981; }
        input:checked + .slider:before { transform: translateX(14px); background-color: #10b981; box-shadow: 0 0 6px #10b981; }
        
        /* Purple switch for Inward Squeeze */
        input.purple-switch:checked + .slider { background-color: rgba(168, 85, 247, 0.2); border-color: #a855f7; }
        input.purple-switch:checked + .slider:before { background-color: #a855f7; box-shadow: 0 0 6px #a855f7; }

        .custom-slider { -webkit-appearance: none; appearance: none; width: 100%; height: 16px; display: block; background: transparent; margin: 4px 0; outline: none; }
        .custom-slider::-webkit-slider-runnable-track { width: 100%; height: 4px; cursor: pointer; background: #1e293b; border-radius: 2px; border: 1px solid #334155; }
        .custom-slider::-webkit-slider-thumb { border: none; height: 14px; width: 14px; border-radius: 50%; background: #10b981; cursor: pointer; -webkit-appearance: none; appearance: none; margin-top: -6px; box-shadow: 0 0 8px #10b981; }

        .slider-yellow::-webkit-slider-thumb { background: #eab308; box-shadow: 0 0 8px #eab308; }
        .slider-yellow::-webkit-slider-runnable-track { border-color: #713f12; }

        .custom-slider.slider-purple::-webkit-slider-thumb { background: #a855f7; box-shadow: 0 0 8px #a855f7; }
        .custom-slider.slider-purple::-webkit-slider-runnable-track { border-color: #581c87; }

        #status-panel { min-width: 280px; padding-left: 15px; border-left: 1px solid rgba(16, 185, 129, 0.2); }
        #status-text { font-family: monospace; color: #e2e8f0; font-size: 0.75rem; line-height: 1.5; }
        
        .legend { display: flex; flex-direction: column; gap: 3px; margin-top: 4px; font-size: 0.65rem; color: #94a3b8; }
        .legend-item { display: flex; align-items: center; gap: 5px; }
        .dot { width: 7px; height: 7px; border-radius: 50%; }

        .pan-btn { padding: 6px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.5); color: #10b981; border-radius: 4px; cursor: pointer; text-transform: uppercase; font-size: 0.6rem; font-weight: bold; transition: all 0.2s; flex: 1; user-select: none; }
        .pan-btn:hover { background: rgba(16, 185, 129, 0.2); }
        .axis-btn { background: #0f172a; color: #f8fafc; border: 1px solid #334155; flex: 0.6; }
        .axis-btn:hover { background: #1e293b; border-color: #475569; }
        
        .metric-good { color: #10b981; font-weight: bold; }
        .metric-bad { color: #ef4444; font-weight: bold; }
        .metric-warn { color: #f59e0b; font-weight: bold; }
        
        .micro-btn { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3); color: #fff; width: 20px; height: 20px; display: flex; justify-content: center; align-items: center; border-radius: 4px; cursor: pointer; font-weight: bold; font-size: 0.7rem; flex-shrink: 0; }
        .micro-btn:hover { background: rgba(255,255,255,0.2); }
        .micro-btn:active { background: rgba(255,255,255,0.4); }
    </style>
</head>
<body>

    <div id="ui-layer">
        <div class="ui-section" style="flex: 1; min-width: 240px;">
            <h1>Archimedean Sieve</h1>
            <p class="subtitle">Radioisotope Remediation Matrix</p>
            
            <div class="legend mt-2 mb-2">
                <div class="legend-item"><div class="dot bg-[#0ea5e9]"></div> Bulk H₂O (Clean Fluid)</div>
                <div class="legend-item"><div class="dot bg-[#39ff14] shadow-[0_0_5px_#39ff14]"></div> HTO / Tritium (Radioactive Target)</div>
                <div class="legend-item"><div class="dot bg-[#a855f7] shadow-[0_0_5px_#a855f7]"></div> 18-Pole Inward Squeeze (nDEP)</div>
                <div class="legend-item"><div class="dot border border-[#10b981]"></div> twDEP Archimedean Corkscrew</div>
            </div>

            <div style="display: flex; gap: 8px; margin-top: 4px;">
                <button id="pan-left-btn" class="pan-btn">&larr; Tilt</button>
                <button id="axis-toggle-btn" class="pan-btn axis-btn">Axis: X</button>
                <button id="pan-right-btn" class="pan-btn">Tilt &rarr;</button>
            </div>
            
            <div class="text-[9px] text-slate-400 font-bold bg-slate-900/80 border border-emerald-900/50 p-2 rounded mt-2 text-center shadow-[0_0_10px_rgba(0,0,0,0.5)]">
                DRAG to rotate camera • SCROLL to zoom
            </div>
        </div>

        <div class="ui-section" style="flex: 2; min-width: 320px; border-left: 1px solid rgba(255,255,255,0.05); padding-left: 15px;">
            <div class="toggles-grid" style="margin-top: 2px;">
                
                <div style="background: rgba(168, 85, 247, 0.05); border: 1px solid rgba(168, 85, 247, 0.2); padding: 8px; border-radius: 6px; margin-top: 4px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                        <span class="toggle-title text-purple-400">18-Pole Inward Squeeze (nDEP)</span>
                        <span id="ndep-label" class="font-mono text-purple-400 font-bold text-xs">80%</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <button id="ndep-minus" class="micro-btn">-</button>
                        <input type="range" id="ndep-slider" class="custom-slider slider-purple" min="0" max="100" step="1" value="80" style="margin:0;">
                        <button id="ndep-plus" class="micro-btn">+</button>
                    </div>
                </div>

                <div style="background: rgba(16, 185, 129, 0.05); border: 1px solid rgba(16, 185, 129, 0.2); padding: 8px; border-radius: 6px; margin-top: 4px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                        <span class="toggle-title text-emerald-400">Archimedean Corkscrew (twDEP)</span>
                        <span id="twdep-label" class="font-mono text-emerald-400 font-bold text-xs">80%</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <button id="twdep-minus" class="micro-btn">-</button>
                        <input type="range" id="twdep-slider" class="custom-slider" min="0" max="100" step="1" value="80" style="margin:0;">
                        <button id="twdep-plus" class="micro-btn">+</button>
                    </div>
                </div>

                <div class="toggle-row" style="margin-top: 4px;">
                    <div class="toggle-label">
                        <span class="toggle-title text-yellow-400">Acousto-Electric Ratchet</span>
                        <span class="toggle-desc">Breaks friction, allows hopped-spiral extraction.</span>
                    </div>
                    <label class="switch"><input type="checkbox" id="toggle-ratchet" checked><span class="slider" style="border-color:#eab308;"></span></label>
                </div>

                <div style="grid-column: 1 / -1; background: rgba(16, 185, 129, 0.05); border: 1px solid rgba(16, 185, 129, 0.2); padding: 8px; border-radius: 6px; margin-top: 4px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2px;">
                        <span class="toggle-title text-emerald-400">Fluid Velocity (Flow Rate)</span>
                        <span id="speed-label" class="font-mono text-emerald-400 font-bold text-xs">1.0x</span>
                    </div>
                    <input type="range" id="speed-slider" class="custom-slider" min="0.1" max="3.0" step="0.1" value="1.0">
                </div>

            </div>
        </div>

        <div class="ui-section" id="status-panel">
            <h2 class="text-[9px] font-black text-slate-500 uppercase tracking-widest mb-2">Extraction Telemetry</h2>
            <div id="status-text">Initializing Mechanics...</div>
        </div>
    </div>

    <div id="canvas-container"></div>

    <script>
        // --- THREE.JS SETUP ---
        const container = document.getElementById('canvas-container');
        const scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x020617, 0.006);

        let width = container.clientWidth;
        let height = container.clientHeight;

        const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
        camera.position.set(0, 0, 130);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(width, height);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        container.appendChild(renderer.domElement);

        const controls = new THREE.OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
        controls.target.set(0, -10, 0);

        // --- MASTER GROUP ---
        const sieveGroup = new THREE.Group();
        scene.add(sieveGroup);

        // --- LIGHTING ---
        const ambientLight = new THREE.AmbientLight(0x0f172a, 3.0);
        scene.add(ambientLight);

        const dirLight = new THREE.DirectionalLight(0xffffff, 1.5);
        dirLight.position.set(20, 40, 30);
        scene.add(dirLight);

        const glowLight = new THREE.PointLight(0x10b981, 1.5, 60);
        glowLight.position.set(0, -15, 0);
        sieveGroup.add(glowLight);

        // --- GEOMETRY: CONDUITS ---
        const pipeMaterial = new THREE.MeshPhysicalMaterial({
            color: 0x1e293b,
            metalness: 0.1,
            roughness: 0.1,
            transparent: true,
            opacity: 0.35,
            side: THREE.DoubleSide,
            depthWrite: false
        });

        const pipeWireframe = new THREE.MeshBasicMaterial({
            color: 0x334155,
            wireframe: true,
            transparent: true
